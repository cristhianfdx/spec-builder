#!/usr/bin/env bash
# post-edit.sh — runs after Claude edits any file
# Generated by spec-builder
#
# Receives via stdin: JSON with { tool, path, ... }
# Use this hook to run linters, formatters, or test runners after edits.

set -euo pipefail

INPUT=$(cat)
FILE=$(echo "$INPUT" | grep -o '"path":"[^"]*"' | head -1 | cut -d'"' -f4)

if [ -z "$FILE" ] || [ ! -f "$FILE" ]; then
  exit 0
fi

# ── Customize below: add your linter/formatter/test runner ──────────────────

# Example: run ruff on Python files
# if [[ "$FILE" == *.py ]]; then
#   ruff check "$FILE" --fix --quiet || true
#   ruff format "$FILE" --quiet || true
# fi

# Example: run eslint on JS/TS files
# if [[ "$FILE" == *.js || "$FILE" == *.ts ]]; then
#   npx eslint "$FILE" --fix --quiet || true
# fi

# Example: run go fmt on Go files
# if [[ "$FILE" == *.go ]]; then
#   gofmt -w "$FILE" || true
# fi

# ─────────────────────────────────────────────────────────────────────────────

exit 0
