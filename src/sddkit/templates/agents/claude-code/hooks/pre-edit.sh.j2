#!/usr/bin/env bash
# pre-edit.sh — runs before Claude edits any file
# Generated by spec-builder
#
# Receives via stdin: JSON with { tool, path, ... }
# Exit 0 = allow, Exit 1 = block with message to stderr

set -euo pipefail

# Read the event from stdin
INPUT=$(cat)

# Extract the file path being edited
FILE=$(echo "$INPUT" | grep -o '"path":"[^"]*"' | head -1 | cut -d'"' -f4)

# Warn if editing outside the project structure defined in constitution.md
if [ -n "$FILE" ]; then
  # Walk up to find .specify/
  ROOT=""
  DIR="$(pwd)"
  for _ in 1 2 3 4 5; do
    if [ -d "$DIR/.specify" ]; then ROOT="$DIR"; break; fi
    DIR="$(dirname "$DIR")"
  done

  if [ -n "$ROOT" ] && [ -f "$ROOT/.specify/memory/constitution.md" ]; then
    # Check if there are any pending tasks before editing
    PENDING=$(grep -r '^\- \[ \]' "$ROOT/.specify/specs/" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$PENDING" -eq 0 ]; then
      echo "Warning: no pending tasks found in .specify/specs/. Validate consistency before editing." >&2
    fi
  fi
fi

exit 0
