# stop.ps1 — runs when Claude finishes a session
# Generated by spec-builder

$Root = $null
$Dir = Get-Location
for ($i = 0; $i -lt 5; $i++) {
    if (Test-Path (Join-Path $Dir ".specify")) { $Root = $Dir; break }
    $Parent = Split-Path $Dir -Parent
    if (-not $Parent -or $Parent -eq $Dir) { break }
    $Dir = $Parent
}

if (-not $Root) { exit 0 }

$SpecsDir = Join-Path $Root ".specify\specs"
$Pending = 0
$Done = 0

if (Test-Path $SpecsDir) {
    $Pending = (Select-String -Path (Join-Path $SpecsDir "**\tasks.md") -Pattern "^\- \[ \]" -Recurse -ErrorAction SilentlyContinue | Measure-Object).Count
    $Done    = (Select-String -Path (Join-Path $SpecsDir "**\tasks.md") -Pattern "^\- \[x\]" -Recurse -ErrorAction SilentlyContinue | Measure-Object).Count
}

Write-Host ""
Write-Host "Session summary:"
Write-Host "  Total pending tasks remaining: $Pending"
Write-Host "  Total completed tasks        : $Done"

exit 0
