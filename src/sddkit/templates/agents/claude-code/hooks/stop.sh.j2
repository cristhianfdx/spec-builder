#!/usr/bin/env bash
# stop.sh — runs when Claude finishes a session
# Generated by spec-builder

set -euo pipefail

ROOT=""
DIR="$(pwd)"
for _ in 1 2 3 4 5; do
  if [ -d "$DIR/.specify" ]; then ROOT="$DIR"; break; fi
  DIR="$(dirname "$DIR")"
done

if [ -z "$ROOT" ]; then exit 0; fi

# Count pending tasks across all specs
PENDING=$(grep -r '^\- \[ \]' "$ROOT/.specify/specs/" 2>/dev/null | wc -l | tr -d ' ')
DONE=$(grep -r '^\- \[x\]' "$ROOT/.specify/specs/" 2>/dev/null | wc -l | tr -d ' ')

echo ""
echo "Session summary:"
echo "  Tasks completed this session : check git diff for details"
echo "  Total pending tasks remaining: $PENDING"
echo "  Total completed tasks        : $DONE"

if [ "$PENDING" -gt 0 ]; then
  echo ""
  echo "Pending tasks:"
  grep -r '^\- \[ \]' "$ROOT/.specify/specs/" 2>/dev/null | \
    sed 's|.*specs/||' | sed 's|/tasks.md:| → |' || true
fi

exit 0
