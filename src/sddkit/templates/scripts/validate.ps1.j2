# validate.ps1 — Validate the .specify/ structure for this project
# Generated by spec-builder

$ErrorActionPreference = "Stop"
$Issues = 0
$OkCount = 0

function Check-Ok($msg) { Write-Host "  OK  $msg"; $script:OkCount++ }
function Check-Fail($msg) { Write-Host "  FAIL $msg"; $script:Issues++ }

$Root = $null
$Dir = Get-Location
for ($i = 0; $i -lt 5; $i++) {
    if (Test-Path (Join-Path $Dir ".specify")) { $Root = $Dir; break }
    $Parent = Split-Path $Dir -Parent
    if (-not $Parent -or $Parent -eq $Dir) { break }
    $Dir = $Parent
}

if (-not $Root) {
    Write-Error "No .specify/ directory found. Run 'sdd init' first."
    exit 1
}

Write-Host ""
Write-Host "Validating: $Root"
Write-Host ""

if (Test-Path (Join-Path $Root ".specify"))                        { Check-Ok ".specify/ exists" }        else { Check-Fail ".specify/ missing" }
if (Test-Path (Join-Path $Root ".specify\memory\constitution.md")) { Check-Ok "constitution.md present" } else { Check-Fail "constitution.md missing" }
if (Test-Path (Join-Path $Root ".specify\prompts"))                { Check-Ok ".specify\prompts\ exists" } else { Check-Fail ".specify\prompts\ missing" }

$SpecsDir = Join-Path $Root ".specify\specs"
if (Test-Path $SpecsDir) {
    foreach ($SpecDir in Get-ChildItem -Directory $SpecsDir) {
        foreach ($File in @("spec.md", "plan.md", "tasks.md")) {
            if (Test-Path (Join-Path $SpecDir.FullName $File)) { Check-Ok "$($SpecDir.Name)/$File" }
            else { Check-Fail "$($SpecDir.Name)/$File missing" }
        }
    }
} else {
    Check-Fail "No specs found in .specify\specs\"
}

Write-Host ""
if ($Issues -gt 0) {
    Write-Host "$Issues issue(s) found. $OkCount check(s) passed."
    exit 1
} else {
    Write-Host "All $OkCount checks passed."
}
