#!/usr/bin/env bash
# new-spec.sh — Create a new spec folder with spec.md, plan.md, and tasks.md
# Usage: ./new-spec.sh "feature-name"
# Generated by spec-builder

set -euo pipefail

FEATURE="${1:-}"

if [ -z "$FEATURE" ]; then
  echo "Usage: $0 <feature-name>"
  echo "Example: $0 manage-users"
  exit 1
fi

ROOT=""
DIR="$(pwd)"
for _ in 1 2 3 4 5; do
  if [ -d "$DIR/.specify" ]; then ROOT="$DIR"; break; fi
  DIR="$(dirname "$DIR")"
done

if [ -z "$ROOT" ]; then
  echo "Error: no .specify/ directory found. Run 'sdd init' first."
  exit 1
fi

SPECS_DIR="$ROOT/.specify/specs"
mkdir -p "$SPECS_DIR"

COUNT=$(find "$SPECS_DIR" -maxdepth 1 -mindepth 1 -type d | wc -l)
NUMBER=$(printf "%03d" $((COUNT + 1)))
SLUG=$(echo "$FEATURE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
FOLDER="${NUMBER}-${SLUG}"
SPEC_DIR="$SPECS_DIR/$FOLDER"

if [ -d "$SPEC_DIR" ]; then
  echo "Error: spec folder already exists: $SPEC_DIR"
  exit 1
fi

mkdir -p "$SPEC_DIR"

cat > "$SPEC_DIR/spec.md" << EOF
# Spec ${NUMBER}: ${FEATURE}

## Status
draft

## Dependencies
none

## Context

## Objective

## Normative Reference
This spec inherits and fully respects \`.specify/memory/constitution.md\`.

## Acceptance Criteria

1. <!-- Criterion 1 -->
2. <!-- Criterion 2 -->

## Out of Scope
Refer to the constitution for global exclusions.
EOF

cat > "$SPEC_DIR/plan.md" << EOF
# Technical Plan — ${FEATURE}

## Architecture

## Module Responsibilities

| Module | Responsibility |
|---|---|

## Technical Decisions

1. <!-- Decision and rationale -->

## Traceability
Immutable rules: \`.specify/memory/constitution.md\`
Acceptance criteria: \`spec.md\`
EOF

cat > "$SPEC_DIR/tasks.md" << EOF
# Tasks

- [ ] <!-- Task 1 -->
- [ ] <!-- Task 2 -->
EOF

echo "Created: $SPEC_DIR"
echo "  - spec.md"
echo "  - plan.md"
echo "  - tasks.md"
