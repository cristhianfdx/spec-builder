# new-spec.ps1 — Create a new spec folder with spec.md, plan.md, and tasks.md
# Usage: .\new-spec.ps1 "feature-name"
# Generated by spec-builder

param(
    [Parameter(Mandatory=$true)]
    [string]$FeatureName
)

$ErrorActionPreference = "Stop"

# Find .specify/ root (walk up max 5 levels)
$Root = $null
$Dir = Get-Location
for ($i = 0; $i -lt 5; $i++) {
    if (Test-Path (Join-Path $Dir ".specify")) {
        $Root = $Dir
        break
    }
    $Dir = Split-Path $Dir -Parent
    if (-not $Dir) { break }
}

if (-not $Root) {
    Write-Error "No .specify/ directory found. Run 'sdd init' first."
    exit 1
}

$SpecsDir = Join-Path $Root ".specify\specs"
New-Item -ItemType Directory -Force -Path $SpecsDir | Out-Null

# Next spec number
$Count = (Get-ChildItem -Directory $SpecsDir -ErrorAction SilentlyContinue | Measure-Object).Count
$Number = "{0:D3}" -f ($Count + 1)

# Slugify feature name
$Slug = $FeatureName.ToLower() -replace '[^a-z0-9]', '-' -replace '-+', '-' -replace '^-|-$', ''
$FolderName = "${Number}-${Slug}"
$SpecDir = Join-Path $SpecsDir $FolderName

if (Test-Path $SpecDir) {
    Write-Error "Spec folder already exists: $SpecDir"
    exit 1
}

New-Item -ItemType Directory -Force -Path $SpecDir | Out-Null
$Date = Get-Date -Format "yyyy-MM-dd"

# spec.md
@"
# Spec ${Number}: ${FeatureName}

## Status
draft

## Dependencies
none

## Context
<!-- Describe the background and motivation for this feature. -->

## Objective
<!-- One sentence: what does this spec deliver? -->

## Normative Reference
This spec inherits and fully respects `.specify/memory/constitution.md`.

## Acceptance Criteria

1. <!-- Criterion 1 -->
2. <!-- Criterion 2 -->

## Out of Scope
Refer to the constitution for global exclusions.
"@ | Set-Content -Path (Join-Path $SpecDir "spec.md") -Encoding UTF8

# plan.md
@"
# Technical Plan — ${FeatureName}

## Architecture
<!-- High-level structure and how this fits into the system. -->

## Module Responsibilities

| Module | Responsibility |
|---|---|
| <!-- module --> | <!-- what it does --> |

## Technical Decisions

1. <!-- Decision and rationale -->

## Traceability
Immutable rules: `.specify/memory/constitution.md`
Acceptance criteria: `spec.md`
"@ | Set-Content -Path (Join-Path $SpecDir "plan.md") -Encoding UTF8

# tasks.md
@"
# Tasks

- [ ] <!-- Task 1 -->
- [ ] <!-- Task 2 -->
"@ | Set-Content -Path (Join-Path $SpecDir "tasks.md") -Encoding UTF8

Write-Host "Created: $SpecDir"
Write-Host "  - spec.md"
Write-Host "  - plan.md"
Write-Host "  - tasks.md"
