#!/usr/bin/env bash
# validate.sh — Validate the .specify/ structure for this project
# Generated by spec-builder

set -euo pipefail

ISSUES=0
OK=0

check_ok() { echo "  OK  $1"; OK=$((OK+1)); }
check_fail() { echo "  FAIL $1"; ISSUES=$((ISSUES+1)); }

# Find .specify/ root
ROOT=""
DIR="$(pwd)"
for _ in 1 2 3 4 5; do
  if [ -d "$DIR/.specify" ]; then ROOT="$DIR"; break; fi
  DIR="$(dirname "$DIR")"
done

if [ -z "$ROOT" ]; then
  echo "FAIL No .specify/ directory found. Run 'sdd init' first."
  exit 1
fi

echo ""
echo "Validating: $ROOT"
echo ""

[ -d "$ROOT/.specify" ]                          && check_ok ".specify/ exists"              || check_fail ".specify/ missing"
[ -f "$ROOT/.specify/memory/constitution.md" ]   && check_ok "constitution.md present"       || check_fail "constitution.md missing"
[ -d "$ROOT/.specify/prompts" ]                  && check_ok ".specify/prompts/ exists"       || check_fail ".specify/prompts/ missing"

SPECS_DIR="$ROOT/.specify/specs"
if [ -d "$SPECS_DIR" ]; then
  for SPEC_DIR in "$SPECS_DIR"/*/; do
    [ -d "$SPEC_DIR" ] || continue
    SPEC_NAME=$(basename "$SPEC_DIR")
    for FILE in spec.md plan.md tasks.md; do
      [ -f "$SPEC_DIR/$FILE" ] && check_ok "$SPEC_NAME/$FILE" || check_fail "$SPEC_NAME/$FILE missing"
    done
  done
else
  check_fail "No specs found in .specify/specs/"
fi

echo ""
if [ "$ISSUES" -gt 0 ]; then
  echo "$ISSUES issue(s) found. $OK check(s) passed."
  exit 1
else
  echo "All $OK checks passed."
fi
